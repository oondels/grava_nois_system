# -----------------------------------------------------------------------------
# Grava Nois System - exemplo de variaveis de ambiente
# Copie este arquivo para .env e ajuste os valores para o seu ambiente.
# -----------------------------------------------------------------------------

# =============================================================================
# 1) Captura de video - fonte principal (RTSP / multicamera)
# =============================================================================
# Modo camera unica
GN_RTSP_URL=rtsp://user:pass@192.168.1.100:554/stream1

# Modos multicamera (opcionais; prioridade: GN_CAMERAS_JSON > GN_RTSP_URLS > GN_RTSP_URL)
# GN_RTSP_URLS=rtsp://user:pass@192.168.1.101:554/stream1,rtsp://user:pass@192.168.1.102:554/stream1
# GN_CAMERAS_JSON=[{"id":"cam01","name":"Quadra 1","rtsp_url":"rtsp://user:pass@192.168.1.101:554/stream1","enabled":true}]

# Fallback de captura local V4L2 (usado quando nenhuma RTSP estiver definida)
GN_INPUT_FRAMERATE=30
GN_VIDEO_SIZE=1280x720

# =============================================================================
# 2) Captura de video - estabilidade RTSP e segmentacao
# =============================================================================
# Health check RTSP
GN_RTSP_MAX_RETRIES=10
GN_RTSP_TIMEOUT=5
GN_FFMPEG_STARTUP_CHECK_SEC=1.0

# Segmentacao e buffer circular
GN_SEG_TIME=1
GN_RTSP_PRE_SEGMENTS=6
GN_RTSP_POST_SEGMENTS=3
GN_BUFFER_DIR=/dev/shm/grn_buffer

# Encoder RTSP
# 0 = recodifica (mais estavel), 1 = passthrough/copy (menor CPU)
GN_RTSP_PASSTHROUGH=0
# Para 30 FPS, use 30. Para 25 FPS, use 25.
GN_RTSP_GOP=25
# Preset x264: ultrafast, superfast, veryfast, faster, fast, medium...
GN_RTSP_PRESET=veryfast
# CRF menor = melhor qualidade/arquivo maior (faixa tipica: 18-28)
GN_RTSP_CRF=23
# VSync RTSP: 2=vfr (menos frames duplicados), 1=cfr, 0=passthrough
GN_RTSP_VSYNC=2

# =============================================================================
# 3) API e identificacao do contexto (cliente/local/device)
# =============================================================================
GN_API_BASE=
GN_API_TOKEN=
GN_CLIENT_ID=
GN_VENUE_ID=
DEVICE_ID=

# =============================================================================
# 4) Seguranca de assinatura HMAC do device
# =============================================================================
DEVICE_SECRET=
# 1=true habilita dry-run da assinatura HMAC (nao envia request)
GN_HMAC_DRY_RUN=0

# =============================================================================
# 5) Worker de processamento
# =============================================================================
# 0=normal (watermark/thumbnail), 1=leve (sem watermark/thumbnail)
GN_LIGHT_MODE=0
GN_MAX_ATTEMPTS=3
# Vazio = default dinamico (numero de cameras ativas)
GN_TRIGGER_MAX_WORKERS=

# Modos de desenvolvimento
DEV=false
# Payload com flag dev no register de metadados
DEV_VIDEO_MODE=false

# =============================================================================
# 6) Fontes de trigger fisico (GPIO/Pico)
# =============================================================================
# auto | gpio | pico | both
GN_TRIGGER_SOURCE=auto
GN_PICO_TRIGGER_TOKEN=BTN_REPLAY
# GN_PICO_PORT=/dev/serial/by-id/usb-Raspberry_Pi_Pico_XXXXXXXXXXXXXXXX-if00

# GPIO (usado quando GN_TRIGGER_SOURCE inclui gpio)
GN_GPIO_PIN=
GN_GPIO_DEBOUNCE_MS=300
GN_GPIO_COOLDOWN_SEC=120

# =============================================================================
# 7) Janela operacional (horario local)
# =============================================================================
GN_TIME_ZONE=America/Sao_Paulo
GN_START_TIME=07:00
GN_END_TIME=23:30

# =============================================================================
# 8) Logging e plataforma
# =============================================================================
# GN_LOG_DIR=/usr/src/app/logs
# Forca deteccao de plataforma durante testes: 1=true | 0=false | vazio=auto
# GN_FORCE_RASPBERRY_PI=

# =============================================================================
# 9) Compatibilidade com variaveis legadas (opcional)
# =============================================================================
# API_BASE_URL=
# API_TOKEN=
# CLIENT_ID=
# VENUE_ID=
# GN_DEVICE_ID=
# GN_DEVICE_SECRET=
# HMAC_DRY_RUN=0
# GPIO_PIN=17
