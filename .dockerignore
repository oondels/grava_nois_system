# =============================================================================
# Grava Nóis System — .dockerignore
# =============================================================================
# O container só precisa de: main.py, src/, requirements.txt, files/
# Tudo abaixo é excluído do contexto de build para reduzir tamanho e
# evitar vazar segredos ou dados de runtime na imagem.

# ── Git ───────────────────────────────────────────────────────────────────────
.git/
.gitignore

env_to_config.sh

# ── Documentação ─────────────────────────────────────────────────────────────
docs/
README.md
CHANGELOG.md

# ── Testes ───────────────────────────────────────────────────────────────────
tests/
.pytest_cache/

# ── Provisionamento WiFi (host-level, não roda no container) ─────────────────
provisioning/

# ── Firmware do Raspberry Pico (MicroPython, não roda no container) ───────────
raspberry_pico/

# ── Ambiente virtual Python ───────────────────────────────────────────────────
.venv/
venv/

# ── Cache Python ──────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd

# ── Segredos e configuração de ambiente ──────────────────────────────────────
.env
.env.*

# ── Orquestração (não necessária dentro do container) ────────────────────────
docker-compose.yml
Dockerfile

# ── Scripts de setup e utilitários de host ───────────────────────────────────
gn_start.sh

# ── Scripts utilitários não importados pelo sistema principal ────────────────
optimze_image.py
check_stdin.py
video_core.py

# ── Diretórios de runtime (montados como volumes pelo docker-compose) ─────────
logs/
queue_raw/
recorded_clips/
highlights_wm/
failed_clips/

# ── Arquivos de runtime e temporários ────────────────────────────────────────
*.log
*.mp4
*.ts
*.jpg
*.jpeg
*.error.txt

# ── IDE e ferramentas locais ──────────────────────────────────────────────────
.vscode/
.claude/
.idea/
